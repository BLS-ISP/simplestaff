#!/usr/bin/env python3

#
# SimpleStaff - NS8 create-module action
# Initial setup: creates state directories and sets default image references.
#

import os
import agent

# Ensure the state directories exist
os.makedirs(os.path.expanduser('~/.config/state/postgres_data'), exist_ok=True)

# Set the container image references for use in the systemd service
agent.set_env('POSTGRES_IMAGE', os.environ.get('POSTGRES_IMAGE', 'docker.io/library/postgres:15-alpine'))
agent.set_env('SIMPLESTAFF_BACKEND_IMAGE', os.environ.get('SIMPLESTAFF_BACKEND_IMAGE', 'ghcr.io/bls-isp/simplestaff-backend:latest'))
agent.set_env('SIMPLESTAFF_FRONTEND_IMAGE', os.environ.get('SIMPLESTAFF_FRONTEND_IMAGE', 'ghcr.io/bls-isp/simplestaff-frontend:latest'))
