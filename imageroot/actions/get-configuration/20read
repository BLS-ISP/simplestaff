#!/usr/bin/env python3

#
# SimpleStaff - NS8 get-configuration action
# Returns current module configuration as JSON to stdout.
#

import os
import json
import sys
import traceback

def log_error(msg):
    print(f"ERROR: {msg}", file=sys.stderr)

try:
    # Import agent to initialize NS8 environment
    import agent
except Exception as e:
    log_error(f"Failed to import NS8 agent: {e}")
    traceback.print_exc(file=sys.stderr)
    sys.exit(1)

try:
    # Read environment variables loaded by runagent from state/environment
    lets_encrypt_str = os.environ.get('LETS_ENCRYPT', 'True')
    http2https_str = os.environ.get('HTTP2HTTPS', 'True')

    config = {
        "domain_name": os.environ.get('DOMAIN_NAME', ''),
        "super_admin_email": os.environ.get('SUPER_ADMIN_EMAIL', ''),
        "super_admin_password": os.environ.get('SUPER_ADMIN_PASSWORD', ''),
        "lets_encrypt": lets_encrypt_str.lower() in ('true', '1', 'yes'),
        "http2https": http2https_str.lower() in ('true', '1', 'yes'),
    }

    # Print to stdout (which is captured by NS8 task runner as output)
    json.dump(config, fp=sys.stdout)
    sys.stdout.flush()

except Exception as e:
    log_error(f"Unexpected error during get-configuration: {e}")
    traceback.print_exc(file=sys.stderr)
    sys.exit(1)
