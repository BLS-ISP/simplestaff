#!/bin/bash
# ============================================
# SimpleStaff - Nethserver 8 get-configuration
# ============================================

set -e

# Define state file path
STATE_DIR="/home/$(whoami)/.config/state"
ENV_FILE="$STATE_DIR/environment"

# Default fallback values
DOMAIN_NAME="time.bls-isp.net"
SUPER_ADMIN_EMAIL="admin@test.local"
SUPER_ADMIN_PASSWORD=""

# Load values if file exists
if [ -f "$ENV_FILE" ]; then
    # Safely source to extract variables
    source "$ENV_FILE"
fi

# Output JSON to stdout for Nethserver Agent
cat <<EOF
{
  "domain_name": "${DOMAIN_NAME}",
  "super_admin_email": "${SUPER_ADMIN_EMAIL}",
  "super_admin_password": "${SUPER_ADMIN_PASSWORD}"
}
EOF
