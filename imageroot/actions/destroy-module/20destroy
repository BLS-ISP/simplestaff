#!/usr/bin/env python3

#
# SimpleStaff - NS8 destroy-module action
# Cleans up Traefik routes and deletes module state.
#

import agent
import agent.tasks
import os
import sys
import traceback

def log_error(msg):
    print(f"ERROR: {msg}", file=sys.stderr)

try:
    module_id = os.environ.get('MODULE_ID')
    print(f"Destroying module={module_id}...", file=sys.stderr)

    traefik_agent_id = agent.resolve_agent_id('traefik@node')
    print(f"Resolved Traefik agent ID: {traefik_agent_id}", file=sys.stderr)

    # Delete Traefik reverse proxy route
    response = agent.tasks.run(
        agent_id=traefik_agent_id,
        action='delete-route',
        data={
            'instance': module_id,
        },
    )
    print(f"Traefik delete-route completed with exit_code={response.get('exit_code')}", file=sys.stderr)

except Exception as e:
    log_error(f"Unexpected error during destroy-module: {e}")
    traceback.print_exc(file=sys.stderr)
    # Don't fail the whole destroy process, just log
