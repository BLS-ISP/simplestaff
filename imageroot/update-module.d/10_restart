#!/bin/bash
# ============================================
# SimpleStaff - NS8 Update Module Hook
# ============================================

exec 1>&2  # Redirect stdout to stderr for journald logging
echo "SimpleStaff: Update hook starting..."

if [ -f environment ]; then
    echo "SimpleStaff: Loading environment variables..."
    set -a
    . ./environment
    set +a
fi

echo "SimpleStaff: Reloading systemd daemon..."
systemctl --user daemon-reload || true

echo "SimpleStaff: Restarting simplestaff.service..."
systemctl --user restart simplestaff.service || true

echo "SimpleStaff: Update hook completed successfully."
exit 0
