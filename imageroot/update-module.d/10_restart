#!/bin/bash
# ============================================
# SimpleStaff - NS8 Update Module Hook
# ============================================
# This script runs after NS8 pulls a new module image.
# NethServer 8 core automatically pulls the updated container images
# referenced in org.nethserver.images. We only need to restart the service.

set -e
exec 1>&2  # Redirect stdout to stderr for journald logging

echo "SimpleStaff: Update hook starting..."

if [ -f environment ]; then
    set -a
    . ./environment
    set +a
fi

systemctl --user daemon-reload
systemctl --user restart simplestaff.service || true

echo "SimpleStaff: Update completed successfully."
