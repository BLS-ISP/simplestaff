#!/bin/bash
# ============================================
# SimpleStaff - Nethserver 8 configure-module
# ============================================

set -e

# Read configuration JSON from stdin
config_json=$(cat)

# Parse or fallback to defaults using jq
DATABASE_PASSWORD=$(echo "$config_json" | jq -r '.database_password // empty')
JWT_SECRET=$(echo "$config_json" | jq -r '.jwt_secret // empty')
SUPER_ADMIN_EMAIL=$(echo "$config_json" | jq -r '.super_admin_email // "admin@time.bls-isp.net"')
SUPER_ADMIN_PASSWORD=$(echo "$config_json" | jq -r '.super_admin_password // "admin123"')
DOMAIN_NAME=$(echo "$config_json" | jq -r '.domain_name // "time.bls-isp.net"')

# Define paths
STATE_DIR="/home/$(whoami)/.config/state"
mkdir -p "$STATE_DIR"
ENV_FILE="$STATE_DIR/environment"

# Load existing values if file exists to prevent overwriting secrets
if [ -f "$ENV_FILE" ]; then
    source "$ENV_FILE"
fi

# Generate cryptographically secure keys if not already set
if [ -z "$DATABASE_PASSWORD" ]; then
    DATABASE_PASSWORD=$(openssl rand -hex 16)
fi

if [ -z "$JWT_SECRET" ]; then
    JWT_SECRET=$(openssl rand -hex 32)
fi

# Write environment file for systemd
cat <<EOF > "$ENV_FILE"
DATABASE_PASSWORD=$DATABASE_PASSWORD
JWT_SECRET=$JWT_SECRET
SUPER_ADMIN_EMAIL=$SUPER_ADMIN_EMAIL
SUPER_ADMIN_PASSWORD=$SUPER_ADMIN_PASSWORD
DOMAIN_NAME=$DOMAIN_NAME
EOF

# Ensure the postgres volume directory exists
mkdir -p "$STATE_DIR/postgres_data"

# Reload systemd and restart the application service
systemctl --user daemon-reload
systemctl --user enable simplestaff.service
systemctl --user restart simplestaff.service

echo "SimpleStaff module configured successfully."
